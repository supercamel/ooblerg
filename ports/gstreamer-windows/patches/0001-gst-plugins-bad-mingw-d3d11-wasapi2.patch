+template<typename TOperation, typename THandler>
+class AsyncEventDelegate: public THandler
+{
+public:
+    AsyncEventDelegate()
+        : _refCount(1), _completedEvent(CreateEventEx(nullptr, nullptr, 0, EVENT_ALL_ACCESS))
+    {
+    }
+
+    virtual ~AsyncEventDelegate()
+    {
+        if (_completedEvent)
+            CloseHandle(_completedEvent);
+    }
+
+    HRESULT STDMETHODCALLTYPE QueryInterface(REFIID riid, void **object) override
+    {
+        if (!object)
+            return E_POINTER;
+
+        if (IsEqualIID(riid, __uuidof(IUnknown)) ||
+            IsEqualIID(riid, __uuidof(THandler))) {
+            *object = static_cast<THandler *>(this);
+            AddRef();
+            return S_OK;
+        }
+
+        *object = nullptr;
+        return E_NOINTERFACE;
+    }
+
+    ULONG STDMETHODCALLTYPE AddRef() override
+    {
+        return InterlockedIncrement(&_refCount);
+    }
+
+    ULONG STDMETHODCALLTYPE Release() override
+    {
+        ULONG count = InterlockedDecrement(&_refCount);
+        if (!count)
+            delete this;
+        return count;
+    }
+
+    HRESULT STDMETHODCALLTYPE Invoke(TOperation* pOperation, AsyncStatus status) override
+    {
+        SetEvent(_completedEvent);
+        return S_OK;
+    }
+
+    HRESULT SyncWait(_In_ TOperation* pOperation, _In_ DWORD dwMilliseconds)
+    {
+        HRESULT hr;
+        DWORD dwWait;
+
+        if (!pOperation)
+            return E_INVALIDARG;
+        if (!_completedEvent)
+            return HRESULT_FROM_WIN32(GetLastError());
+
+        hr = pOperation->put_Completed(this);
+        if (FAILED(hr))
+            return hr;
+
+        dwWait = WaitForSingleObjectEx(_completedEvent, dwMilliseconds, TRUE);
+        if (WAIT_IO_COMPLETION == dwWait || WAIT_OBJECT_0 == dwWait)
+            return S_OK;
+
+        return HRESULT_FROM_WIN32(GetLastError());
+    }
+
+private:
+    volatile LONG _refCount;
+    HANDLE _completedEvent;
+};
+
+template <typename TOperation, typename THandler>
+HRESULT SyncWait(_In_ TOperation* pOperation, _In_ DWORD dwMilliseconds)
+{
+    auto spCallback = new (std::nothrow) AsyncEventDelegate<TOperation, THandler>();
+    HRESULT hr;
+
+    if (!spCallback)
+        return E_OUTOFMEMORY;
+
+    hr = spCallback->SyncWait(pOperation, dwMilliseconds);
+    spCallback->Release();
+
+    return hr;
+}
+
+template <typename TResult>
+HRESULT SyncWait(_In_ ABI::Windows::Foundation::IAsyncOperation<TResult>* pOperation, _In_ DWORD dwMilliseconds = INFINITE)

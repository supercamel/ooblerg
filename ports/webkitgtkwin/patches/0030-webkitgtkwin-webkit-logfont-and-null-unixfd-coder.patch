From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: WebKitGTKWin Port <webkitgtkwin@ooblerg.local>
Date: Wed, 17 Jun 2026 00:00:00 +0000
Subject: [PATCH] WebKitGTKWin: add LOGFONT wrapper and null Unix FD coder

The Windows Cairo font serializer now includes the LOGFONT wrapper that the
generated IPC code expects. GTK-on-Windows also still generates accelerated
backing messages containing UnixFileDescriptor; provide a Windows-only null
coder for that type so those Unix-only message fields compile and decode as
invalid descriptors until the accelerated backing backend is split properly.
---
 Source/WebKit/Platform/IPC/ArgumentCoders.h | 23 +++++++++
 Source/WebKit/Shared/CoreIPCLOGFONT.h       | 58 +++++++++++++++++++++
 2 files changed, 81 insertions(+)

diff --git a/Source/WebKit/Platform/IPC/ArgumentCoders.h b/Source/WebKit/Platform/IPC/ArgumentCoders.h
index fdad92b..1f3b11b 100644
--- a/Source/WebKit/Platform/IPC/ArgumentCoders.h
+++ b/Source/WebKit/Platform/IPC/ArgumentCoders.h
@@ -53,8 +53,31 @@
 #if USE(UNIX_DOMAIN_SOCKETS)
 #include "ArgumentCodersUnix.h"
 #endif
+#if OS(WINDOWS)
+#include <wtf/unix/UnixFileDescriptor.h>
+#endif
 
 namespace IPC {
+
+#if OS(WINDOWS)
+template<> struct ArgumentCoder<WTF::UnixFileDescriptor> {
+    template<typename Encoder>
+    static void encode(Encoder&, const WTF::UnixFileDescriptor&)
+    {
+    }
+
+    template<typename Encoder>
+    static void encode(Encoder&, WTF::UnixFileDescriptor&&)
+    {
+    }
+
+    template<typename Decoder>
+    static std::optional<WTF::UnixFileDescriptor> decode(Decoder&)
+    {
+        return WTF::UnixFileDescriptor { };
+    }
+};
+#endif
 
 template<typename T, size_t Extent> struct ArgumentCoder<std::span<T, Extent>> {
     template<typename Encoder>
diff --git a/Source/WebKit/Shared/CoreIPCLOGFONT.h b/Source/WebKit/Shared/CoreIPCLOGFONT.h
new file mode 100644
index 0000000..714c942
--- /dev/null
+++ b/Source/WebKit/Shared/CoreIPCLOGFONT.h
@@ -0,0 +1,58 @@

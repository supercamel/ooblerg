+#pragma once
+
+#if OS(WINDOWS) && USE(CAIRO)
+
+#include <span>
+#include <windows.h>
+
+namespace WebKit {
+
+class CoreIPCLOGFONT {
+public:
+    explicit CoreIPCLOGFONT(const LOGFONT& logFont)
+        : m_logFont(logFont)
+    {
+    }
+
+    static LOGFONT create(std::span<const LOGFONT, 1> data)
+    {
+        return data[0];
+    }
+
+    std::span<const LOGFONT, 1> data() const
+    {
+        return std::span<const LOGFONT, 1> { &m_logFont, 1 };
+    }
+
+private:
+    LOGFONT m_logFont { };
+};
+
+} // namespace WebKit
+
+#endif // OS(WINDOWS) && USE(CAIRO)

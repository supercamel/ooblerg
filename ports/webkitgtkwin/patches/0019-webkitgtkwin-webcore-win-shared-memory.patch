From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: WebKitGTKWin Port <webkitgtkwin@local>
Date: Wed, 17 Jun 2026 00:00:00 +0000
Subject: [PATCH] WebKitGTKWin: add a Win32 SharedMemory backend

GTK and WPE normally use Unix domain sockets, but GTK-on-Windows must not pick
UnixFileDescriptor-backed shared memory. Keep the platform-independent
SharedMemory interface, leave the Unix backend in place, and add a Win32
backend that carries duplicated HANDLEs through WTF::Win32Handle.
---
 Source/WTF/wtf/PlatformUse.h                  |  2 +-
 Source/WebCore/PlatformGTK.cmake              |  1 +
 Source/WebCore/platform/win/SharedMemoryWin.cpp | 107 ++++++++++++++++++
 3 files changed, 109 insertions(+), 1 deletion(-)

diff --git a/Source/WTF/wtf/PlatformUse.h b/Source/WTF/wtf/PlatformUse.h
index 537936a6f1a2..08f4bf9c3b33 100644
--- a/Source/WTF/wtf/PlatformUse.h
+++ b/Source/WTF/wtf/PlatformUse.h
@@ -179,7 +179,7 @@
 #define USE_METAL 1
 #endif
 
-#if PLATFORM(GTK) || PLATFORM(WPE)
+#if (PLATFORM(GTK) || PLATFORM(WPE)) && !OS(WINDOWS)
 #define USE_UNIX_DOMAIN_SOCKETS 1
 #endif
 
diff --git a/Source/WebCore/PlatformGTK.cmake b/Source/WebCore/PlatformGTK.cmake
index 11d87560a607..e40319f345e7 100644
--- a/Source/WebCore/PlatformGTK.cmake
+++ b/Source/WebCore/PlatformGTK.cmake
@@ -27,6 +27,7 @@ if (USE_CAIRO)
             platform/graphics/win/cairo/FontCacheWinCairo.cpp
             platform/graphics/win/cairo/FontCustomPlatformDataWinCairo.cpp
             platform/graphics/win/cairo/FontPlatformDataWinCairo.cpp
+            platform/win/SharedMemoryWin.cpp
             platform/win/BString.cpp
             platform/win/WebCoreInstanceHandle.cpp
         )
diff --git a/Source/WebCore/platform/win/SharedMemoryWin.cpp b/Source/WebCore/platform/win/SharedMemoryWin.cpp
new file mode 100644
index 000000000000..33e3c156e7bc
--- /dev/null
+++ b/Source/WebCore/platform/win/SharedMemoryWin.cpp
@@ -0,0 +1,107 @@

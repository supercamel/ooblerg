From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: WebKitGTKWin Port <webkitgtkwin@local>
Date: Wed, 17 Jun 2026 00:00:00 +0000
Subject: [PATCH] WebKitGTKWin: null EGL backend for GTK on Windows

MinGW libepoxy is built with WGL headers, not EGL headers. Keep the EGL-oriented WebCore display interfaces available for the GTK port, but make the Windows GTK implementation fail closed until a real WGL or ANGLE backend is wired in. Also cast the WOFF sfnt offset to the 32-bit field width before calling htonl, avoiding MinGW winsock overload ambiguity.
---
--- a/Source/WebCore/platform/graphics/WOFFFileFormat.cpp
+++ b/Source/WebCore/platform/graphics/WOFFFileFormat.cpp
@@ -264,7 +264,7 @@
         WTF_ALLOW_UNSAFE_BUFFER_USAGE_END
         *sfntTableDirectoryPtr++ = htonl(tableTag);
         *sfntTableDirectoryPtr++ = htonl(tableOrigChecksum);
-        *sfntTableDirectoryPtr++ = htonl(sfnt.size());
+        *sfntTableDirectoryPtr++ = htonl(static_cast<uint32_t>(sfnt.size()));
         *sfntTableDirectoryPtr++ = htonl(tableOrigLength);
         sfntTableDirectoryCursor += 4 * sizeof(uint32_t);
 

+#include <wtf/Vector.h>
 
 namespace WTF {
 
@@ -130,9 +131,29 @@
     info.dwThreadID = GetCurrentThreadId();
     info.dwFlags = 0;
 
+#if COMPILER(MSVC)
     __try {
         RaiseException(MS_VC_EXCEPTION, 0, sizeof(info) / sizeof(ULONG_PTR), reinterpret_cast<ULONG_PTR*>(&info));
     } __except(EXCEPTION_CONTINUE_EXECUTION) { }
+#else
+    // MinGW GCC does not support MSVC SEH syntax. Prefer the modern Windows
+    // thread-description API when it is present, resolving it dynamically so
+    // older Windows releases still run this backend.
+    using SetThreadDescriptionPtr = HRESULT (WINAPI *)(HANDLE, PCWSTR);
+    static SetThreadDescriptionPtr setThreadDescription = [] {
+        HMODULE kernel32 = GetModuleHandleW(L"kernel32.dll");
+        if (!kernel32)
+            return static_cast<SetThreadDescriptionPtr>(nullptr);
+        return reinterpret_cast<SetThreadDescriptionPtr>(GetProcAddress(kernel32, "SetThreadDescription"));
+    }();
+
+    if (setThreadDescription) {
+        int wideNameLength = MultiByteToWideChar(CP_UTF8, 0, info.szName, -1, nullptr, 0);
+        Vector<wchar_t> wideName(wideNameLength);
+        if (wideNameLength > 0 && MultiByteToWideChar(CP_UTF8, 0, info.szName, -1, wideName.mutableSpan().data(), wideNameLength))
+            setThreadDescription(GetCurrentThread(), wideName.span().data());
+    }
+#endif
 
     initializeCurrentThreadEvenIfNonWTFCreated();

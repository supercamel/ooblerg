{
  "name": "Ooblerg Package Manager",
  "app_id": "dev.ooblerg.pkgmanager",
  "icon": "assets/icons/dev.ooblerg.pkgmanager.png",
  "desktop_terminal": false,
  "desktop_categories": [
    "Development",
    "GTK"
  ],
  "script": "main.nut",
  "target": "appimage",
  "resources": [
    "assets"
  ],
  "files": [
    {
      "path": "assets/icons/hicolor/index.theme",
      "dest": "usr/share/icons/hicolor/index.theme"
    },
    {
      "path": "assets/icons/dev.ooblerg.pkgmanager.png",
      "dest": "usr/share/icons/hicolor/1024x1024/apps/dev.ooblerg.pkgmanager.png"
    },
    {
      "path": "assets/icons/ooblerg-icon.png",
      "dest": "usr/share/icons/hicolor/1024x1024/apps/ooblerg-icon.png"
    }
  ],
  "sqgi_source": {
    "repo": "https://github.com/supercamel/sqgi.git",
    "ref": "3a5051af8aa8485a3ed0e2596b46ef2182bd1d81"
  },
  "linux": {
    "arches": [
      {
        "arch": "x86_64",
        "build_dir": "build-linux-x86_64",
        "deb": {
          "download": true,
          "suite": "jammy",
          "packages": [
            "libgtk-4-1",
            "gir1.2-gtk-4.0",
            "libsoup-3.0-0",
            "gir1.2-soup-3.0",
            "libglib2.0-0",
            "libgirepository-1.0-1"
          ]
        },
        "build": [
          "cmake -E rm -rf \"$SQGI_LINUX_BUILD_DIR\"",
          "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_LINUX_BUILD_DIR\" -G Ninja ${SQGI_LINUX_CMAKE_TOOLCHAIN:+-DCMAKE_TOOLCHAIN_FILE=\"$SQGI_LINUX_CMAKE_TOOLCHAIN\"} -DCMAKE_BUILD_TYPE=Release -DSQ_ENABLE_JIT=ON",
          "cmake --build \"$SQGI_LINUX_BUILD_DIR\""
        ]
      }
    ]
  },
  "windows": {
    "msys2_prefix": "mingw64",
    "gdk_backend": "win32",
    "build_dir": "build-windows-x86_64",
    "nsis_options": {
      "icon": "assets/icons/ooblerg-icon.ico"
    },
    "files": [
      {
        "path": "assets/icons/hicolor/index.theme",
        "dest": "share/icons/hicolor/index.theme"
      },
      {
        "path": "assets/icons/dev.ooblerg.pkgmanager.png",
        "dest": "share/icons/hicolor/1024x1024/apps/dev.ooblerg.pkgmanager.png"
      },
      {
        "path": "assets/icons/ooblerg-icon.png",
        "dest": "share/icons/hicolor/1024x1024/apps/ooblerg-icon.png"
      },
      {
        "path": "certs/ca-bundle.crt",
        "dest": "share/ooblerg/certs/ca-bundle.crt"
      },
      {
        "path": "certs/ca-bundle.crt",
        "dest": "etc/ssl/certs/ca-bundle.crt"
      },
      {
        "path": "certs/ca-bundle.crt",
        "dest": "etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem"
      }
    ],
    "packages": [
      "mingw-w64-x86_64-libsoup3",
      "mingw-w64-x86_64-glib-networking",
      "mingw-w64-x86_64-gsettings-desktop-schemas",
      "mingw-w64-x86_64-ca-certificates",
      "mingw-w64-x86_64-openssl"
    ],
    "native_projects": [
      {
        "dir": "native",
        "build": [
          "BUILD_DIR=build-windows-x86_64 MESON_CROSS_FILE=\"$SQGI_MESON_CROSS_FILE\" ./build.sh"
        ],
        "libraries": [
          "build-windows-x86_64/libooblerg-win-1.0.dll"
        ],
        "typelibs": [
          "build-windows-x86_64/OoblergWin-1.0.typelib"
        ]
      }
    ],
    "build": [
      "cmake -E rm -rf \"$SQGI_WINDOWS_BUILD_DIR\"",
      "cmake -S \"$SQGI_SOURCE_DIR\" -B \"$SQGI_WINDOWS_BUILD_DIR\" -G Ninja -DCMAKE_TOOLCHAIN_FILE=\"$SQGI_WIN_CMAKE_TOOLCHAIN\" -DCMAKE_BUILD_TYPE=Release -DSQ_ENABLE_JIT=ON",
      "cmake --build \"$SQGI_WINDOWS_BUILD_DIR\" --target sqgi sqgi-bin"
    ]
  }
}

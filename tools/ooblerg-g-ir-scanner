#!/usr/bin/env python3
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
OUT = ROOT / "out"
REAL_SCANNER = os.environ.get("OOBLERG_REAL_G_IR_SCANNER", "/usr/bin/g-ir-scanner")
PE_LDD = ROOT / "tools" / "ooblerg-pe-ldd"
WINE_WRAPPER = ROOT / "tools" / "ooblerg-wine-wrapper"


def prepend_env_path(name, path):
    if not path.exists():
        return
    existing = os.environ.get(name, "")
    parts = [str(path)]
    parts.extend(part for part in existing.split(os.pathsep) if part)
    os.environ[name] = os.pathsep.join(dict.fromkeys(parts))


def configure_cross_build_env():
    sysroot = OUT / "sysroot"
    prefix = sysroot / "mingw64"
    pkg_dirs = [
        prefix / "lib" / "pkgconfig",
        prefix / "share" / "pkgconfig",
    ]
    existing_pkg_dirs = [str(path) for path in pkg_dirs if path.exists()]
    if existing_pkg_dirs and not os.environ.get("PKG_CONFIG_LIBDIR"):
        os.environ["PKG_CONFIG_LIBDIR"] = os.pathsep.join(existing_pkg_dirs)
    os.environ.setdefault("PKG_CONFIG_SYSROOT_DIR", str(sysroot))
    os.environ.setdefault("PKG_CONFIG_ALLOW_SYSTEM_CFLAGS", "1")
    os.environ.setdefault("PKG_CONFIG_ALLOW_SYSTEM_LIBS", "1")

    libdir = prefix / "lib"
    prepend_env_path("LIBRARY_PATH", libdir)
    lib_flag = f"-L{libdir}"
    existing_ldflags = os.environ.get("LDFLAGS", "")
    if libdir.exists() and lib_flag not in existing_ldflags.split():
        os.environ["LDFLAGS"] = f"{lib_flag} {existing_ldflags}".strip()


def output_path(args):
    for index, arg in enumerate(args):
        if arg == "--output" and index + 1 < len(args):
            return Path(args[index + 1])
        if arg.startswith("--output="):
            return Path(arg.split("=", 1)[1])
    return None


def normalize_windows_shared_libraries(path):
    if not path or not path.exists():
        return
    text = path.read_text()

    def normalize(match):
        return match.group(0).replace(".-", "-")

    updated = re.sub(r'shared-library="[^"]+"', normalize, text)
    if updated != text:
        path.write_text(updated)


def dll_candidates(alias):
    if not alias.lower().endswith(".dll"):
        return []
    stem = alias[:-4]
    if not stem.startswith("lib"):
        return []
    roots = [OUT / "build", OUT / "sysroot"]
    candidates = []
    for root in roots:
        if root.exists():
            candidates.extend(root.rglob(f"{stem}-*.dll"))
    return sorted(candidates, key=lambda p: (len(str(p)), str(p)))


def rewrite_shlib_aliases(path):
    if not path or not path.exists():
        return
    text = path.read_text()
    replacements = {}
    for alias in sorted(set(re.findall(r"lib[A-Za-z0-9_.+-]+\.dll", text))):
        if (OUT / "build").joinpath(alias).exists() or (OUT / "sysroot").joinpath(alias).exists():
            continue
        candidates = dll_candidates(alias)
        if candidates:
            replacements[alias] = candidates[0].name
    for alias, real in replacements.items():
        text = text.replace(alias, real)
    if replacements:
        path.write_text(text)


def scanner_libraries(args):
    libraries = []
    for index, arg in enumerate(args):
        if arg in {"--library", "--extra-library"} and index + 1 < len(args):
            libraries.append(args[index + 1])
        elif arg.startswith("--library="):
            libraries.append(arg.split("=", 1)[1])
        elif arg.startswith("--extra-library="):
            libraries.append(arg.split("=", 1)[1])
    return libraries


def add_dll_dirs(args):
    dirs = [
        OUT / "sysroot" / "mingw64" / "bin",
        OUT / "sysroot" / "mingw64" / "lib",
    ]
    for index, arg in enumerate(args):
        if arg == "-L" and index + 1 < len(args):
            dirs.append(Path(args[index + 1]))
        elif arg.startswith("-L") and len(arg) > 2:
            dirs.append(Path(arg[2:]))
        elif arg == "--library-path" and index + 1 < len(args):
            dirs.append(Path(args[index + 1]))
        elif arg.startswith("--library-path="):
            dirs.append(Path(arg.split("=", 1)[1]))

    existing = os.environ.get("OOBLERG_DLL_DIRS", "")
    dll_dirs = [str(path) for path in dirs if path.exists()]
    dll_dirs.extend(path for path in existing.split(os.pathsep) if path)
    unique = list(dict.fromkeys(dll_dirs))
    if unique:
        os.environ["OOBLERG_DLL_DIRS"] = os.pathsep.join(unique)


def configure_cross_launcher():
    if os.environ.get("OOBLERG_EXE_WRAPPER"):
        os.environ["GI_CROSS_LAUNCHER"] = str(WINE_WRAPPER)
        return True
    if os.environ.get("GI_CROSS_LAUNCHER"):
        return True
    wine = shutil.which("wine") or shutil.which("wine64")
    if not wine:
        return False
    os.environ["OOBLERG_EXE_WRAPPER"] = wine
    os.environ["GI_CROSS_LAUNCHER"] = str(WINE_WRAPPER)
    return True


def has_option(args, name):
    return any(arg == name or arg.startswith(name + "=") for arg in args)


def main():
    argv = [REAL_SCANNER]
    configure_cross_build_env()
    add_dll_dirs(sys.argv[1:])

    env = os.environ.copy()
    if configure_cross_launcher():
        launcher = os.environ.get("GI_CROSS_LAUNCHER", str(WINE_WRAPPER))
        if not has_option(sys.argv[1:], "--use-binary-wrapper"):
            argv.append(f"--use-binary-wrapper={launcher}")
        if not has_option(sys.argv[1:], "--use-ldd-wrapper"):
            argv.append(f"--use-ldd-wrapper={PE_LDD}")
        if not has_option(sys.argv[1:], "--lib-dirs-envvar"):
            argv.append("--lib-dirs-envvar=OOBLERG_DLL_DIRS")
        env["OOBLERG_GIR_LIBRARIES"] = os.pathsep.join(scanner_libraries(sys.argv[1:]))

    argv.extend(sys.argv[1:])
    status = subprocess.call(argv, env=env)
    if status == 0:
        path = output_path(sys.argv[1:])
        normalize_windows_shared_libraries(path)
        rewrite_shlib_aliases(path)
    raise SystemExit(status)


if __name__ == "__main__":
    main()

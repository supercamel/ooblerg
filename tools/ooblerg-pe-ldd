#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
OUT = ROOT / "out"


def scanner_name(name):
    lower = name.lower()
    if not lower.startswith("lib") or not lower.endswith(".dll"):
        return name
    stem = name[:-4]
    head, sep, tail = stem.rpartition("-")
    if sep and tail.isdigit():
        return f"{head}.-{tail}.dll"
    return name


def imported_dlls(binary):
    target = os.environ.get("OOBLERG_TARGET", "x86_64-w64-mingw32")
    try:
        output = subprocess.check_output([f"{target}-objdump", "-p", binary], text=True)
    except (OSError, subprocess.CalledProcessError):
        return []
    dlls = []
    for line in output.splitlines():
        line = line.strip()
        if line.startswith("DLL Name:"):
            dlls.append(line.split(":", 1)[1].strip())
    return dlls


def alias_for(dll):
    lower = dll.lower()
    if not lower.startswith("lib") or not lower.endswith(".dll"):
        return None
    stem = dll[:-4]
    head, sep, tail = stem.rpartition("-")
    if sep and tail.isdigit():
        return f"{head}.dll"
    return None


def dll_search_roots():
    roots = [OUT / "build", OUT / "sysroot"]
    for raw in os.environ.get("OOBLERG_DLL_DIRS", "").split(os.pathsep):
        if raw:
            roots.append(Path(raw))
    return roots


def find_dll_for_library(library):
    alias = f"lib{library}.dll"
    aliases = {alias.lower(), f"{alias[:-4]}-0.dll".lower()}
    matches = []
    for root in dll_search_roots():
        if not root.exists():
            continue
        pattern = "*.dll" if root.is_dir() and root.name in {"bin", "lib"} else f"{alias[:-4]}*.dll"
        for path in root.rglob(pattern):
            lower = path.name.lower()
            if lower in aliases or alias_for(path.name) == alias:
                matches.append(path)
    return sorted(matches, key=lambda p: (len(str(p)), str(p)))[0] if matches else None


def requested_libraries():
    raw = os.environ.get("OOBLERG_GIR_LIBRARIES", "")
    return [item for item in raw.split(os.pathsep) if item]


def emit(emitted, alias, real):
    visible = scanner_name(alias)
    key = visible.lower()
    if key in emitted:
        return
    print(f"        {visible} => {real} (0x00000000)")
    emitted.add(key)


def emit_dll_dirs(emitted):
    for raw in os.environ.get("OOBLERG_DLL_DIRS", "").split(os.pathsep):
        if not raw:
            continue
        root = Path(raw)
        if not root.is_dir():
            continue
        for path in sorted(root.glob("*.dll")):
            emit(emitted, path.name, path.name)


def main():
    if len(sys.argv) != 2:
        print("usage: ooblerg-pe-ldd BINARY", file=sys.stderr)
        return 2

    emitted = set()
    binary = Path(sys.argv[1])
    if not binary.exists() and binary.suffix == "":
        exe_binary = binary.with_name(binary.name + ".exe")
        if exe_binary.exists():
            binary = exe_binary
    if binary.suffix.lower() == ".dll":
        emit(emitted, binary.name, binary.name)

    for dll in imported_dlls(str(binary)):
        emit(emitted, dll, dll)
        alias = alias_for(dll)
        if alias:
            emit(emitted, alias, dll)

    for library in requested_libraries():
        alias = f"lib{library}.dll"
        dll = find_dll_for_library(library)
        if dll:
            emit(emitted, alias, dll.name)

    emit_dll_dirs(emitted)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

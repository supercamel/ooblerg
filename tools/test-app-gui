#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP="$(mktemp -d "${TMPDIR:-/tmp}/ooblerg-gui-test.XXXXXX")"
SERVER_PID=""
PORT="${OOBLERG_TEST_PORT:-}"
PACKAGE="${OOBLERG_TEST_PACKAGE:-cairo}"
TIMEOUT_MS="${OOBLERG_TEST_TIMEOUT_MS:-30000}"

cleanup() {
    if [[ -n "${SERVER_PID}" ]] && kill -0 "${SERVER_PID}" 2>/dev/null; then
        kill "${SERVER_PID}" 2>/dev/null || true
        wait "${SERVER_PID}" 2>/dev/null || true
    fi
    if [[ "${OOBLERG_TEST_KEEP_TMP:-0}" != "1" ]]; then
        rm -rf "${TMP}"
    else
        echo "[gui-harness] kept logs in ${TMP}"
    fi
}
trap cleanup EXIT

pick_port() {
    python3 - <<'PY'
import socket
s = socket.socket()
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PY
}

wait_for_server() {
    local url="http://127.0.0.1:${PORT}/healthz"
    for _ in $(seq 1 100); do
        if curl -fsS "${url}" >/dev/null 2>&1; then
            return 0
        fi
        if ! kill -0 "${SERVER_PID}" 2>/dev/null; then
            echo "[gui-harness] server exited early"
            cat "${TMP}/server.log" || true
            return 1
        fi
        sleep 0.1
    done
    echo "[gui-harness] timed out waiting for ${url}"
    cat "${TMP}/server.log" || true
    return 1
}

cd "${ROOT}"

if [[ -z "${PORT}" ]]; then
    PORT="$(pick_port)"
fi

echo "[gui-harness] rebuilding repository metadata"
if ! sqgi server/main.nut --rebuild-index >"${TMP}/rebuild.log" 2>&1; then
    cat "${TMP}/rebuild.log"
    exit 1
fi

echo "[gui-harness] starting server on 127.0.0.1:${PORT}"
sqgi server/main.nut --server --port="${PORT}" >"${TMP}/server.log" 2>&1 &
SERVER_PID="$!"
wait_for_server

INDEX_URL="http://127.0.0.1:${PORT}/v1/index.json"
PKG_COUNT="$(curl -fsS "${INDEX_URL}" | jq '.packages | length')"
if [[ "${PKG_COUNT}" -lt 1 ]]; then
    echo "[gui-harness] repository index is empty"
    exit 1
fi
echo "[gui-harness] repository has ${PKG_COUNT} packages"

MANIFEST_URL="http://127.0.0.1:${PORT}/v1/packages/native-sdk/native-sdk-1-x86_64-w64-mingw32.pkg.json"
curl -fsS "${MANIFEST_URL}" |
    jq -e 'any(.dependencies[].name; . == "gcc") and all(.dependencies[].name; . != "busybox-w32")' >/dev/null
echo "[gui-harness] native-sdk manifest includes gcc and excludes busybox-w32"

APP_ENV=(
    env
    "GDK_BACKEND=x11"
    "GIO_USE_VFS=local"
    "GTK_USE_PORTAL=0"
    "NO_AT_BRIDGE=1"
    "GSK_RENDERER=cairo"
    "LIBGL_ALWAYS_SOFTWARE=1"
    "XDG_DATA_HOME=${TMP}/xdg-data"
    "XDG_CACHE_HOME=${TMP}/xdg-cache"
)
APP_CMD=(
    sqgi app/main.nut
    --gtk-smoke-test
    "--source-uri=${INDEX_URL}"
    "--test-package=${PACKAGE}"
    "--test-timeout-ms=${TIMEOUT_MS}"
)

echo "[gui-harness] running GTK smoke test for ${PACKAGE}"
if command -v xvfb-run >/dev/null 2>&1; then
    if ! xvfb-run -a "${APP_ENV[@]}" "${APP_CMD[@]}" >"${TMP}/app.log" 2>&1; then
        cat "${TMP}/app.log"
        echo "[gui-harness] server log:"
        cat "${TMP}/server.log"
        exit 1
    fi
else
    if ! "${APP_ENV[@]}" "${APP_CMD[@]}" >"${TMP}/app.log" 2>&1; then
        cat "${TMP}/app.log"
        echo "[gui-harness] server log:"
        cat "${TMP}/server.log"
        exit 1
    fi
fi

grep '^\[OK\]' "${TMP}/app.log"
echo "[gui-harness] OK"
